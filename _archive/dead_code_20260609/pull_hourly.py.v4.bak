#!/usr/bin/env python3
"""
Hourly Bars Pull v4 — Polite Concurrency
=========================================
Polygon aggs range queries:
  - 8-11s per 5-year hourly scan (server-side index scan)
  - 12 concurrent workers → server-side throttling (67% timeouts)
  - 3 concurrent workers + 1s gaps → 100% success rate
  - Unlimited API calls on Starter plan (verified May 2026 pricing)

Strategy:
  - 3 workers with 1s inter-call delay (avoid concurrency throttling)
  - 30s timeout (generous buffer for 10s queries)
  - 0 retries (these never 429 — just slow)
  - No pagination (50000 limit fits 99% of hourly bar sets)
  - Writer thread drains NDJSON as results arrive
  - Checkpoint tracks SUCCESSFUL tickers only (skip failed on resume)
  - Expected: ~0.3 tkr/s → ~3 hours for 3,000 tickers

Usage:
  python3 pull_hourly.py              # pull missing → NDJSON → DB
  python3 pull_hourly.py --insert-only  # just merge existing NDJSON
"""

import os, sys, json, time, logging, threading, queue
from datetime import date
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor, as_completed

# ── Config ────────────────────────────────────────────────────────────────
BASE_DIR = Path.home() / "market-data"
DB_PATH = BASE_DIR / "market_data.duckdb"
RAW_DIR = BASE_DIR / "raw"
CKPT_PATH = BASE_DIR / "hourly_checkpoint.json"
SECTOR_MAP = Path.home() / "earnings-reports" / "sector_map_vti.csv"

HISTORY_START = "2021-06-01"
HISTORY_END = date.today().isoformat()
MAX_WORKERS = 2
INTER_CALL_GAP = 1.5       # seconds between call starts (reduce queue contention)
API_TIMEOUT = 30           # Polygon takes 9-12s for 5yr range scans
TICKER_TIMEOUT = 60        # per-future timeout (covers 30s call + buffer)
RETRIES = 0                # these never 429 — just slow. don't retry.

sys.path.insert(0, str(BASE_DIR))
from polygon_client import PolygonClient

# Polygon Starter = Unlimited calls. 30s timeout for slow range queries.
client = PolygonClient(timeout=API_TIMEOUT, retries=RETRIES)

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s',
    handlers=[logging.StreamHandler(sys.stdout)]
)
log = logging.getLogger("pull_hourly")

# ── Ticker Loading ────────────────────────────────────────────────────────

def load_vti_tickers() -> list[str]:
    tickers = []
    with open(SECTOR_MAP) as f:
        next(f)
        for line in f:
            t = line.split(",")[0].strip().upper()
            if t:
                tickers.append(t)
    return tickers


def get_missing_tickers() -> list[str]:
    """Return VTI tickers not in hourly_bars. Falls back to full list if DB locked."""
    import duckdb
    all_vti = sorted(set(load_vti_tickers()))

    try:
        db = duckdb.connect(str(DB_PATH))
        have = set(r[0] for r in db.execute("SELECT DISTINCT ticker FROM hourly_bars").fetchall())
        db.close()
        missing = [t for t in all_vti if t not in have]
        log.info(f"VTI: {len(all_vti):,} | In DB: {len(have):,} | To pull: {len(missing):,}")
        return missing
    except Exception as e:
        log.warning(f"DB locked — pulling all {len(all_vti):,} VTI tickers (INSERT will dedup)")
        return all_vti


# ── Checkpoint ────────────────────────────────────────────────────────────

def load_checkpoint() -> dict:
    if CKPT_PATH.exists():
        return json.loads(CKPT_PATH.read_text())
    return {}

def save_checkpoint(cp: dict):
    CKPT_PATH.write_text(json.dumps(cp, indent=2))


# ── Core: Pull one ticker → list of row tuples (NO disk I/O) ──────────────

def pull_hourly_ticker(ticker: str) -> list[tuple]:
    """
    Pull ALL hourly bars for one ticker. Returns list of (ticker, ts, o, h, l, c, v, vw, n).
    NO pagination — 50000 limit fits 99% of tickers. One page only.
    """
    path = f"/v2/aggs/ticker/{ticker}/range/1/hour/{HISTORY_START}/{HISTORY_END}"
    resp = client._get(path, {"limit": 50000, "sort": "asc"})

    # Aggs endpoint doesn't return "status" on success — only ticker/resultsCount/results.
    # Error responses have "status": "ERROR". Check for results instead of _ok().
    if not isinstance(resp, dict) or resp.get("status") == "ERROR":
        return []

    results = resp.get("results", [])
    if not results:
        return []

    rows = []
    for bar in results:
        rows.append((
            ticker, bar["t"],
            bar.get("o"), bar.get("h"), bar.get("l"), bar.get("c"),
            bar.get("v"), bar.get("vw"), bar.get("n")
        ))
    return rows


# ── Phase 1: Pull ALL → writer thread drains to NDJSON ────────────────────

def pull_all(tickers: list[str]):
    """
    Pull ALL tickers in the list. DB dedup handles already-inserted data.
    Crash recovery: stale NDJSON is inserted in main() before pull_all() runs.
    No checkpoint needed — DB is the source of truth for what's missing.
    """
    remaining = list(tickers)  # all tickers passed in are already filtered by DB

    if not remaining:
        log.info("Hourly: already complete")
        return

    log.info(f"Pulling {len(remaining):,} tickers | {MAX_WORKERS} workers | {API_TIMEOUT}s timeout | {INTER_CALL_GAP}s gap")
    est_sec = len(remaining) / (MAX_WORKERS / 25.0)  # ~25s avg per ticker (12-50s range)
    log.info(f"Expected: ~{est_sec:.0f}s (~{est_sec/60:.0f} min)")
    t0 = time.time()

    # Shared state — separate "attempted" from "succeeded"
    row_queue = queue.Queue()
    stats = {"attempted": 0, "succeeded": 0, "failed": 0, "rows": 0, "locked": threading.Lock()}
    # Throttle: track last call time per-worker via a shared token
    last_call = [0.0]
    throttle_lock = threading.Lock()

    # NDJSON writer thread
    ndjson_path = RAW_DIR / "hourly.ndjson"
    if ndjson_path.exists():
        ndjson_path.unlink()

    def writer():
        rows_written = 0
        with open(ndjson_path, "a") as f:
            while True:
                try:
                    batch = row_queue.get(timeout=3)
                    if batch is None:  # sentinel
                        break
                    lines = []
                    for row in batch:
                        lines.append(json.dumps({
                            "_ticker": row[0], "t": row[1],
                            "o": row[2], "h": row[3], "l": row[4], "c": row[5],
                            "v": row[6], "vw": row[7], "n": row[8]
                        }) + "\n")
                    f.writelines(lines)
                    f.flush()
                    rows_written += len(batch)
                    row_queue.task_done()
                except queue.Empty:
                    continue
        log.info(f"Writer: {rows_written:,} rows flushed to disk")

    writer_thread = threading.Thread(target=writer, daemon=True)
    writer_thread.start()

    def pull_one(ticker):
        # Inter-call throttle: ensure minimum gap between starts
        with throttle_lock:
            elapsed = time.time() - last_call[0]
            if elapsed < INTER_CALL_GAP:
                time.sleep(INTER_CALL_GAP - elapsed)
            last_call[0] = time.time()

        rows = pull_hourly_ticker(ticker)
        success = len(rows) > 0
        if success:
            row_queue.put(rows)
            with stats["locked"]:
                stats["rows"] += len(rows)
                stats["succeeded"] += 1
        else:
            with stats["locked"]:
                stats["failed"] += 1

        with stats["locked"]:
            stats["attempted"] += 1
            n_success = stats["succeeded"]
            n_attempted = stats["attempted"]
            # Checkpoint ONLY successful tickers (retry failed ones on resume)
            if n_success > 0 and n_success % 200 == 0:
                elapsed = time.time() - t0
                rate = n_success / elapsed if elapsed > 0 else 0
                pct = n_success / len(remaining) * 100
                log.info(f"  [{n_success:,}/{len(remaining):,}] {pct:.0f}% — {rate:.1f} tkr/s — {stats['rows']:,} rows — {stats['failed']} fail")

    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as pool:
        futures = {pool.submit(pull_one, t): t for t in remaining}
        pool_deadline = TICKER_TIMEOUT * max(1, len(remaining) // MAX_WORKERS)
        for f in as_completed(futures, timeout=pool_deadline):
            try:
                f.result(timeout=TICKER_TIMEOUT)
            except Exception:
                with stats["locked"]:
                    stats["failed"] += 1
                    stats["attempted"] += 1

    # Signal writer to stop
    row_queue.put(None)
    writer_thread.join(timeout=60)

    elapsed = time.time() - t0
    log.info(f"Pull done: {stats['succeeded']:,} succeeded, {stats['failed']:,} failed, "
             f"{stats['rows']:,} rows in {elapsed:.0f}s "
             f"({stats['succeeded']/elapsed:.2f} tkr/s)")

    return stats["rows"]


# ── Phase 2: Bulk merge NDJSON → DuckDB ──────────────────────────────────

def bulk_insert_ndjson():
    import duckdb
    path = RAW_DIR / "hourly.ndjson"
    if not path.exists():
        log.info("No hourly.ndjson — nothing to insert")
        return 0

    size_mb = path.stat().st_size / 1024**2
    log.info(f"Bulk merging {size_mb:.0f}MB NDJSON → DuckDB...")
    t0 = time.time()

    db = duckdb.connect(str(DB_PATH))

    # Ensure index exists for fast NOT EXISTS check
    db.execute("CREATE INDEX IF NOT EXISTS idx_hourly_ticker_ts ON hourly_bars(ticker, timestamp)")

    # Pure SQL merge
    db.execute(f"""
        INSERT INTO hourly_bars
        SELECT j._ticker, j.t, j.o, j.h, j.l, j.c, j.v, j.vw, j.n
        FROM read_json('{path}', format='newline_delimited',
                       columns={{_ticker: 'VARCHAR', t: 'BIGINT', o: 'DOUBLE',
                                 h: 'DOUBLE', l: 'DOUBLE', c: 'DOUBLE',
                                 v: 'DOUBLE', vw: 'DOUBLE', n: 'INTEGER'}}) j
        WHERE NOT EXISTS (
            SELECT 1 FROM hourly_bars h
            WHERE h.ticker = j._ticker AND h.timestamp = j.t
        )
    """)

    elapsed = time.time() - t0
    count = db.execute("SELECT COUNT(*) FROM hourly_bars").fetchone()[0]
    tickers = db.execute("SELECT COUNT(DISTINCT ticker) FROM hourly_bars").fetchone()[0]
    db.close()

    log.info(f"  Merge: {count:,} total rows, {tickers:,} tickers in {elapsed:.1f}s")
    return count


# ── Main ──────────────────────────────────────────────────────────────────

def main():
    import argparse
    parser = argparse.ArgumentParser(description="Hourly bars pull v4 — polite concurrency")
    parser.add_argument("--insert-only", action="store_true", help="Skip pull, just merge NDJSON")
    args = parser.parse_args()

    RAW_DIR.mkdir(exist_ok=True)

    if args.insert_only:
        log.info("INSERT-ONLY mode")
        bulk_insert_ndjson()
        return

    # Step 1: Insert any leftover NDJSON from a previous crashed run
    ndjson_path = RAW_DIR / "hourly.ndjson"
    if ndjson_path.exists() and ndjson_path.stat().st_size > 0:
        log.info("Found leftover NDJSON from previous run — inserting first...")
        bulk_insert_ndjson()
        ndjson_path.unlink()  # consumed — clean slate

    # Step 2: Get tickers still missing from DB
    tickers = get_missing_tickers()
    if not tickers:
        log.info("All VTI tickers have hourly data ✓")
        return

    # Step 3: Pull all missing tickers into fresh NDJSON
    total_rows = pull_all(tickers)

    # Step 4: Bulk insert
    if total_rows > 0:
        bulk_insert_ndjson()
        ndjson_path.unlink()  # consumed

    if CKPT_PATH.exists():
        CKPT_PATH.unlink()
    log.info("✅ Hourly pull complete")


if __name__ == "__main__":
    main()
